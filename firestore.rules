rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserProfileExists() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function isAdmin() {
      return currentUserProfileExists()
        && get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    function isAgent() {
      return signedIn() && !isAdmin();
    }

    /*
     * User profiles
     *
     * Path:
     * users/{uid}
     *
     * Agents:
     * - Can read their own profile.
     * - Can create their own profile as an agent.
     * - Can update their own profile without changing their role.
     *
     * Admins:
     * - Can read every profile for the agent selector.
     * - Cannot edit another user's profile.
     *
     * Admin roles must be assigned manually in Firebase.
     */
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.get('role', 'agent') == 'agent';

      allow update: if isOwner(userId)
        && request.resource.data.get('role', 'agent')
          == resource.data.get('role', 'agent');

      allow delete: if false;
    }

    /*
     * Agent-owned data
     *
     * Current AGNT path:
     * users/{uid}/days/{date}
     *
     * The recursive match also protects any future UID-scoped
     * subcollections added beneath a user's profile.
     *
     * Agents:
     * - Can read and write only their own data.
     *
     * Admins:
     * - Can read every agent's data.
     * - Cannot create, update or delete agent data.
     */
    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdmin();

      allow create, update, delete: if isOwner(userId)
        && isAgent();
    }

    /*
     * Shared leaderboard
     *
     * Path:
     * leaderboard/{uid}
     *
     * All authenticated users may read the leaderboard.
     * Agents may publish only their own row.
     * Admin accounts cannot publish or appear through normal app writes.
     */
    match /leaderboard/{userId} {
      allow read: if signedIn();

      allow create, update: if isOwner(userId)
        && isAgent()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.get('role', 'agent') != 'admin';

      allow delete: if isOwner(userId)
        && isAgent();
    }
  }
}
